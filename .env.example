# ==========================================================================
# Template de variaveis de ambiente do EscolaIdiomas.
# Copie para `.env` (ou configure no painel do Render) e preencha os valores.
# NUNCA commite o `.env` real — apenas este `.env.example`.
# ==========================================================================

# --- Banco de dados (Supabase / Postgres) ---
DATABASE_URL=jdbc:postgresql://localhost:5432/escola_idiomas
DB_USER=postgres
DB_PASSWORD=postgres

# --- JWT (autenticacao) ---
# Segredo HS256: use >= 32 bytes (256 bits). Ex.: `openssl rand -base64 48`
JWT_SECRET=troque-por-um-segredo-forte-de-no-minimo-32-bytes
JWT_EXPIRATION_MS=86400000

# --- CORS / URLs ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
APP_WEB_BASE_URL=http://localhost:5173

# --- E-mail (JavaMail / SMTP) ---
# Para testes locais use Mailpit/MailHog (host localhost, porta 1025, sem auth).
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@escolaidiomas.app

# --- Seed do primeiro gestor (opcional) ---
# Se SEED_GESTAO_PASSWORD ficar vazio, o seeder NAO cria a conta.
SEED_GESTAO_NOME=Gestor Padrao
SEED_GESTAO_EMAIL=gestao@escolaidiomas.local
SEED_GESTAO_PASSWORD=

# --- Jobs agendados (cron externo -> endpoint protegido /jobs/**) ---
# Enviado pelo cron no header X-Job-Secret. Vazio = endpoints de job recusam (401).
JOB_TRIGGER_SECRET=troque-por-um-segredo-de-job

# --- PIX (recebedor da escola — BR Code local, sem PSP) ---
# Chave de recebimento (e-mail, telefone +55..., CPF/CNPJ ou EVP) e dados do recebedor no QR.
PIX_CHAVE=pix@escolaidiomas.app
PIX_RECEBEDOR=Escola de Idiomas
PIX_CIDADE=Florianopolis

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8080
