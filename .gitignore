# --- Base do projeto: não versionar ---

# Documentação interna (não sobe pro GitHub)
Docs/

# Configuração do Claude Code (skills, hooks, settings) e contexto interno
.claude/
CLAUDE.md

# Segredos e variáveis de ambiente
.env
.env.*
*.local
# ...mas o template de variáveis (sem segredos) deve ser versionado
!.env.example

# Arquivos de sistema operacional
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# --- Backend (Java / Maven) ---
backend/target/
backend/HELP.md
*.class
*.war
*.jar
# mantém o jar do Maven wrapper mesmo com o *.jar acima
!backend/.mvn/wrapper/maven-wrapper.jar

# --- Frontend (Node / Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDEs ---
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
.settings/
.project
.classpath
